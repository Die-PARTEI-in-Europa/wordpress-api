{
    "name": "parteieuropa/wordpress-api",
    "description": "A PHP SDK for interacting with the WordPress REST API",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "WordPressApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WordPressApi\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "phpstan analyse src tests --level=8"
    }
}
